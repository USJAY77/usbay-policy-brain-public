# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# PYTHON CACHE / BUILD
# -------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.log

# -------------------------
# VIRTUAL ENVIRONMENTS
# -------------------------
.venv/
venv/
env/

# -------------------------
# SECRETS (STRICT BLOCK)
# -------------------------
*.pem
*.key
!policy/public_key.pem
!approvals/dev-ci/approver1_public_key.pem
!approvals/dev-ci/approver2_public_key.pem
approvals/approver*.pem
approvals/policy-approval-*.json
approvals/policy-approval-*.sig
!approvals/dev-ci/
!approvals/dev-ci/*
private_key*
*secret*
!utils/secret_provider.py
*.env
.env*
secrets/
governance/keys/*private*
governance/*private*

# -------------------------
# VAULT / LOCAL STATE
# -------------------------
vault/data/
vault/init-output.json

# -------------------------
# RUNTIME DATA (LOCAL ONLY)
# -------------------------
runtime/*
!runtime/__init__.py
!runtime/enforcement_gateway.py
!runtime/policy_validator.py
!runtime/websocket_server.py

# -------------------------
# AUDIT / EVIDENCE (LOCAL ONLY)
# -------------------------
audit/logs/*
!audit/logs/.gitkeep

python/evidence/*
artifacts/*
!artifacts/.gitkeep
!artifacts/governance-dashboard-audit.json

# -------------------------
# EXPORTS (LOCAL ONLY)
# -------------------------
python/exports/
python/audit/logs/

# -------------------------
# TEST OUTPUT
# -------------------------
*.log
pytest_output.txt
tmp/
tmp/*
demos/edgeguard/out/*
!demos/edgeguard/out/.gitkeep
!demos/edgeguard/out/README.md

# -------------------------
# APPROVAL / CERT STORAGE
# -------------------------
approvals/*.pem

# -------------------------
# IDE / EDITOR
# -------------------------
.vscode/
.idea/

