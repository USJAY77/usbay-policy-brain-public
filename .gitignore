# =========================
# SYSTEM FILES
# =========================
.DS_Store
__pycache__/
*.pyc

# =========================
# VIRTUAL ENVIRONMENTS
# =========================
.venv/
venv/

# =========================
# SECRETS (STRICT BLOCK)
# =========================
*.pem
*.key
private_key*
*secret*
*.env

# =========================
# AUDIT / EVIDENCE (NEVER VERSIONED)
# =========================
audit/logs/*
!audit/logs/.gitkeep

python/evidence/*
artifacts/*
!artifacts/.gitkeep

# =========================
# RUNTIME DATA (LOCAL ONLY)
# =========================
runtime/*
!runtime/__init__.py
!runtime/enforcement_gateway.py
!runtime/policy_validator.py

vault/data/
vault/init-output.json

# =========================
# APPROVAL STORAGE (SENSITIVE)
# =========================
approvals/*.pem

# =========================
# EXPORTS (LOCAL ONLY)
# =========================
python/exports/
python/audit/logs/

# =========================
# TEST OUTPUT
# =========================
*.log
pytest_output.txt

# =========================
# IMPORTANT: DO NOT IGNORE
# =========================
# policy/
# governance/
# audit rulesets
# source code
__pycache__/
*.pyc
tmp/
