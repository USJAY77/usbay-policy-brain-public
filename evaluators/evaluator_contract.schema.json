{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "USBAY Evaluator Decision Contract",
  "type": "object",
  "required": [
    "evaluation_id",
    "rule_id",
    "result",
    "risk_level",
    "requires_approval"
  ],
  "properties": {
    "evaluation_id": { "type": "string" },
    "rule_id": { "type": "string" },
    "result": {
      "type": "string",
      "enum": ["allow", "deny", "review"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "requires_approval": {
      "type": "boolean"
    },
    "explanation": {
      "type": "string"
    }
  }
}
