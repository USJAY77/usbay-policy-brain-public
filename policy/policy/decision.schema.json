{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "USBAY Decision Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "timestamp",
    "subject",
    "requested_action",
    "policy_version",
    "evaluation",
    "approvals",
    "final_decision"
  ],
  "properties": {
    "decision_id": { "type": "string" },
    "timestamp": { "type": "string", "description": "ISO-8601 UTC timestamp" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "channel"],
      "properties": {
        "actor_id": { "type": "string" },
        "channel": { "type": "string", "description": "e.g. api, ui, batch" }
      }
    },
    "requested_action": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "description": "e.g. transfer_funds, delete_record" }
      }
    },
    "policy_version": { "type": "string" },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "risk_level", "rule_hits"],
      "properties": {
        "result": { "type": "string", "enum": ["allow", "deny", "needs_approval"] },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
        "rule_hits": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule_id", "outcome"],
            "properties": {
              "rule_id": { "type": "string" },
              "outcome": { "type": "string", "enum": ["pass", "fail", "warn"] },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "approvals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "required_count", "received"],
      "properties": {
        "status": { "type": "string", "enum": ["not_required", "pending", "approved", "rejected"] },
        "required_count": { "type": "integer", "minimum": 0 },
        "received": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["approver_id", "decision", "timestamp"],
            "properties": {
              "approver_id": { "type": "string" },
              "decision": { "type": "string", "enum": ["approve", "reject"] },
              "timestamp": { "type": "string" }
            }
          }
        }
      }
    },
    "final_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "enforcement_token"],
      "properties": {
        "result": { "type": "string", "enum": ["allow", "deny"] },
        "enforcement_token": { "type": "string", "description": "Token consumed by the gateway control point" }
      }
    }
  }
}
