{
  "schema": "usbay.governance.rfc3161_timestamp_schema.v1",
  "purpose": "Define RFC3161-compatible timestamp metadata required for governance evidence packages, validation results, review decisions, export bundles, and audit lineage records.",
  "runtime_behavior_change": false,
  "aws_resource_creation": false,
  "credentials_allowed": false,
  "certification_claim": false,
  "blocker_status_change": false,
  "default_decision": "BLOCKED",
  "fail_closed": true,
  "required_record_fields": [
    "timestamp_record_id",
    "timestamp_schema",
    "timestamp_subject_type",
    "timestamp_subject_id",
    "timestamp_subject_path",
    "timestamp_subject_sha256",
    "rfc3161_token_sha256",
    "tsa_policy_id",
    "tsa_certificate_sha256",
    "timestamp_utc",
    "previous_timestamp_record_sha256",
    "timestamp_record_sha256",
    "linked_audit_reference",
    "decision"
  ],
  "required_subject_types": [
    "evidence_package",
    "validation_result",
    "review_decision",
    "export_bundle",
    "audit_lineage"
  ],
  "required_relationships": [
    "evidence_package_to_validation_result",
    "validation_result_to_review_decision",
    "review_decision_to_export_bundle",
    "export_bundle_to_audit_lineage"
  ],
  "required_failure_codes": [
    "TIMESTAMP_MISSING",
    "TIMESTAMP_INVALID",
    "TIMESTAMP_CHAIN_INCOMPLETE"
  ],
  "hash_algorithm": "SHA256",
  "allowed_decisions": [
    "BLOCKED",
    "READY_FOR_REVIEW"
  ]
}
